# ====================================================
# 本機開發：複製此檔為 .env，填入真實數值
# GitHub 部署：將這些值設定為 GitHub Repository Secrets
# ====================================================

# Supabase 設定（必填）
VITE_SUPABASE_URL="https://your-project-ref.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Gemini AI（選填）
GEMINI_API_KEY="your-gemini-api-key"
